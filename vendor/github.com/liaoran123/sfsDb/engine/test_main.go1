package engine

import (
	"os"
	"testing"

	"github.com/liaoran123/sfsDb/storage"
)

// TestMain 统一管理测试资源的初始化和清理
func TestMain(m *testing.M) {
	// 初始化数据库
	_, err := storage.OpenDefaultDb("./kvdb")
	if err != nil {
		panic("Failed to open database: " + err.Error())
	}

	// 运行所有测试
	code := m.Run()

	// 清理资源
	storage.CloseDb()

	// 退出测试
	os.Exit(code)
}
