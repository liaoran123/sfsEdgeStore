		if db != nil {
			db.Close()
			storage.KVDb = nil
		}
	}()

	// 创建测试表
	table, err := TableNew("test_transaction_pool")
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置表字段
	fields := map[string]any{
		"id":   0,
		"name": "",
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置表字段失败: %v", err)
	}

	// 创建主键索引
	pk, err := DefaultPrimaryKeyNew("pk_id")
	if err != nil {
		t.Fatalf("创建主键失败: %v", err)
	}
	pk.AddFields("id")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 测试前获取内存统计
	var memStatsBefore runtime.MemStats
	runtime.ReadMemStats(&memStatsBefore)

	// 执行大量事务操作
	const transactions = 1000

	for i := 0; i < transactions; i++ {
		// 开始事务
		tx, err := table.BeginTx(ReadCommitted)
		if err != nil {
			t.Fatalf("开始事务失败: %v", err)
		}

		// 插入记录
		insertRecord := map[string]any{
			"id":   i + 1,
			"name": fmt.Sprintf("记录%d", i+1),
		}
		_, err = tx.Insert(&insertRecord)
		if err != nil {
			tx.Rollback()
			// 忽略重复主键错误
			if !strings.Contains(err.Error(), "主键") {
				t.Fatalf("插入记录失败: %v", err)
			}
		}

		// 提交事务
		err = tx.Commit()
		if err != nil {
			// 忽略重复主键错误
			if !strings.Contains(err.Error(), "主键") {
				t.Fatalf("提交事务失败: %v", err)
			}
		}

		// 每100个事务执行一次垃圾回收
		if (i+1)%100 == 0 {
			runtime.GC()
		}
	}

	// 测试后获取内存统计
	var memStatsAfter runtime.MemStats
	runtime.ReadMemStats(&memStatsAfter)

	// 打印内存使用情况
	fmt.Printf("内存使用情况:\n")
	fmt.Printf("测试前分配内存: %d MB\n", memStatsBefore.Alloc/1024/1024)
	fmt.Printf("测试后分配内存: %d MB\n", memStatsAfter.Alloc/1024/1024)
	fmt.Printf("内存增长: %d MB\n", (memStatsAfter.Alloc-memStatsBefore.Alloc)/1024/1024)

	// 检查内存增长是否合理（不应该超过100MB）
	if (memStatsAfter.Alloc - memStatsBefore.Alloc) > 100*1024*1024 {
		t.Errorf("内存增长过大，可能存在内存泄漏: %d MB", (memStatsAfter.Alloc-memStatsBefore.Alloc)/1024/1024)
	}

	// 验证快照池是否正常工作
	fmt.Printf("快照池测试完成\n")
}

// TestTransactionPerformance 测试事务性能
func TestTransactionPerformance(t *testing.T) {
	// 创建临时目录作为数据库路径
	tempDir := t.TempDir()

	// 显式打开数据库，使用临时目录
	db, err := storage.OpenDefaultDb(tempDir)
	if err != nil {
		t.Fatalf("打开数据库失败: %v", err)
	}

	// 清理测试环境
	defer func() {
		if db != nil {
			db.Close()
			storage.KVDb = nil
		}
	}()

	// 创建测试表
	table, err := TableNew("test_transaction_perf")
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置表字段
	fields := map[string]any{
		"id":   0,
		"name": "",
		"data": "",
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置表字段失败: %v", err)
	}

	// 创建主键索引
	pk, err := DefaultPrimaryKeyNew("pk_id")
	if err != nil {
		t.Fatalf("创建主键失败: %v", err)
	}
	pk.AddFields("id")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 测试事务性能
	const transactions = 100

	// 记录开始时间
	startTime := time.Now()

	for i := 0; i < transactions; i++ {
		// 开始事务
		tx, err := table.BeginTx(ReadCommitted)
		if err != nil {
			t.Fatalf("开始事务失败: %v", err)
		}

		// 插入记录
		insertRecord := map[string]any{
			"id":   i + 1,
			"name": fmt.Sprintf("测试记录%d", i+1),
			"data": fmt.Sprintf("测试数据%d", i+1),
		}
		_, err = tx.Insert(&insertRecord)
		if err != nil {
			tx.Rollback()
			// 忽略重复主键错误
			if !strings.Contains(err.Error(), "主键") {
				t.Fatalf("插入记录失败: %v", err)
			}
		}

		// 提交事务
		err = tx.Commit()
		if err != nil {
			// 忽略重复主键错误
			if !strings.Contains(err.Error(), "主键") {
				t.Fatalf("提交事务失败: %v", err)
			}
		}
	}

	// 记录结束时间
	endTime := time.Now()
	duration := endTime.Sub(startTime)

	// 计算性能指标
	transactionsPerSecond := float64(transactions) / duration.Seconds()
	fmt.Printf("事务性能测试完成:\n")
	fmt.Printf("执行 %d 个事务耗时: %v\n", transactions, duration)
	fmt.Printf("事务处理速度: %.2f 事务/秒\n", transactionsPerSecond)

	// 验证性能是否达标（至少500事务/秒）
	if transactionsPerSecond < 500 {
		t.Logf("警告: 事务性能较低: %.2f 事务/秒", transactionsPerSecond)
	}
}
