package engine

import (
	"fmt"
	"os"
	"testing"
	"time"

	"github.com/liaoran123/sfsDb/storage"
)

// TestTable_SearchRange 测试时序数据的区间搜索功能
func TestTable_SearchRange(t *testing.T) {
	// 清理旧数据
	tableName := "test_search_range_" + t.Name()
	defer os.RemoveAll("./test_search_range_db")

	// 初始化数据库
	_, err := storage.OpenDefaultDb("./test_search_range_db")
	if err != nil {
		t.Fatalf("打开数据库失败: %v", err)
	}
	defer storage.CloseDb()

	// 创建表，使用时间戳作为主键
	table, err := TableNew(tableName)
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置字段，timestamp作为主键（int）
	fields := map[string]any{
		"timestamp": 0,   // 时间戳主键
		"value":     0.0, // 传感器值
		"sensor_id": "",  // 传感器ID
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置字段失败: %v", err)
	}

	// 创建主键索引
	pk, _ := DefaultPrimaryKeyNew("pk")
	pk.AddFields("timestamp")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 生成测试数据（时序数据）
	now := int(time.Now().Unix())
	testData := make([]map[string]any, 100)

	for i := 0; i < 100; i++ {
		testData[i] = map[string]any{
			"timestamp": now + i,
			"value":     float64(i * 10),
			"sensor_id": fmt.Sprintf("sensor_%d", i%10),
		}
	}

	// 插入测试数据
	for _, data := range testData {
		_, err := table.Insert(&data)
		if err != nil {
			t.Fatalf("插入数据失败: %v", err)
		}
	}

	// 测试1: 完全匹配的范围查询
	t.Run("ExactMatchRangeSearch", func(t *testing.T) {
		// 创建测试点
		testPoint := now + 15

		// 定义迭代器函数
		funIter := storage.FunIter(func(start, limit []byte) storage.Iterator {
			// 使用存储引擎的Iterator方法创建范围迭代器
			return table.kvStore.Iterator(start, limit)
		})

		// 执行完全匹配的范围查询
		iter, err := table.SearchRange(funIter, &map[string]any{"timestamp": testPoint}, &map[string]any{"timestamp": testPoint})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果数量
		expectedCount := 1 // 只返回完全匹配的记录
		if len(records) != expectedCount {
			t.Errorf("期望 %d 条记录，实际得到 %d 条", expectedCount, len(records))
		}

		// 验证结果
		for _, record := range records {
			timestamp := record["timestamp"].(int)
			fmt.Printf("完全匹配测试 timestamp: %v\n", timestamp)
			if timestamp != testPoint {
				t.Errorf("记录时间戳 %d 不是期望的值 %d", timestamp, testPoint)
			}
		}
	})

	// 测试2: 相同值的范围查询
	t.Run("SameValueRangeSearch", func(t *testing.T) {
		// 创建测试点
		testPoint := now + 20

		// 定义迭代器函数
		funIter := storage.FunIter(func(start, limit []byte) storage.Iterator {
			// 使用存储引擎的Iterator方法创建范围迭代器
			return table.kvStore.Iterator(start, limit)
		})

		// 执行相同值的范围查询
		iter, err := table.SearchRange(funIter, &map[string]any{"timestamp": testPoint}, &map[string]any{"timestamp": testPoint})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果
		for _, record := range records {
			timestamp := record["timestamp"].(int)
			if timestamp != testPoint {
				t.Errorf("记录时间戳 %d 不是期望的值 %d", timestamp, testPoint)
			}
		}
	})

	// 测试3: 使用默认迭代器
	t.Run("DefaultIterator", func(t *testing.T) {
		// 创建测试点
		testPoint := now + 25

		// 执行范围查询，使用默认迭代器（funIter为nil）
		iter, err := table.SearchRange(nil, &map[string]any{"timestamp": testPoint}, &map[string]any{"timestamp": testPoint})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果
		for _, record := range records {
			timestamp := record["timestamp"].(int)
			if timestamp != testPoint {
				t.Errorf("记录时间戳 %d 不是期望的值 %d", timestamp, testPoint)
			}
		}
	})
}

// TestTable_SearchRange_PrimaryKey 测试当索引为主键时，SearchRange 函数的行为是否符合预期
// 验证：Start 和 Limit 必须包含相同的 key 值，并且只支持完全匹配的范围查询
func TestTable_SearchRange_PrimaryKey(t *testing.T) {
	// 清理旧数据
	tableName := "test_search_range_pk_" + t.Name()
	defer os.RemoveAll("./test_search_range_pk_db")

	// 初始化数据库
	_, err := storage.OpenDefaultDb("./test_search_range_pk_db")
	if err != nil {
		t.Fatalf("打开数据库失败: %v", err)
	}
	defer storage.CloseDb()

	// 创建表
	table, err := TableNew(tableName)
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置字段
	fields := map[string]any{
		"id":    0,   // 主键
		"name":  "",  // 名称
		"value": 0.0, // 值
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置字段失败: %v", err)
	}

	// 创建主键索引
	pk, _ := DefaultPrimaryKeyNew("pk")
	pk.AddFields("id")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 生成测试数据
	testData := make([]map[string]any, 100)

	for i := 0; i < 100; i++ {
		testData[i] = map[string]any{
			"id":    i,
			"name":  fmt.Sprintf("item_%d", i),
			"value": float64(i * 10),
		}
	}

	// 插入测试数据
	for _, data := range testData {
		_, err := table.Insert(&data)
		if err != nil {
			t.Fatalf("插入数据失败: %v", err)
		}
	}

	// 定义迭代器函数
	funIter := storage.FunIter(func(start, limit []byte) storage.Iterator {
		return table.kvStore.Iterator(start, limit)
	})

	// 测试1: 完全匹配的主键查询
	t.Run("ExactMatchPrimaryKey", func(t *testing.T) {
		// 设置测试点
		testID := 50

		// 执行完全匹配的范围查询
		iter, err := table.SearchRange(funIter, &map[string]any{"id": testID}, &map[string]any{"id": testID})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果数量
		expectedCount := 1 // 只返回完全匹配的记录
		if len(records) != expectedCount {
			t.Errorf("期望 %d 条记录，实际得到 %d 条", expectedCount, len(records))
		}

		// 验证结果
		if len(records) > 0 {
			id := records[0]["id"].(int)
			if id != testID {
				t.Errorf("期望 ID 为 %d，实际为 %d", testID, id)
			}
		}
	})

	// 测试2: 不同 key 值的错误处理
	t.Run("DifferentKeysError", func(t *testing.T) {
		// 执行不同 key 值的范围查询
		_, err := table.SearchRange(funIter, &map[string]any{"id": 10}, &map[string]any{"name": "item_10"})
		if err == nil {
			t.Errorf("期望不同 key 值时返回错误，实际没有返回错误")
		}
	})

	// 测试3: 使用默认迭代器的完全匹配查询
	t.Run("DefaultIteratorExactMatch", func(t *testing.T) {
		// 设置测试点
		testID := 75

		// 执行完全匹配的范围查询，使用默认迭代器
		iter, err := table.SearchRange(nil, &map[string]any{"id": testID}, &map[string]any{"id": testID})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果数量
		expectedCount := 1 // 只返回完全匹配的记录
		if len(records) != expectedCount {
			t.Errorf("期望 %d 条记录，实际得到 %d 条", expectedCount, len(records))
		}

		// 验证结果
		if len(records) > 0 {
			id := records[0]["id"].(int)
			if id != testID {
				t.Errorf("期望 ID 为 %d，实际为 %d", testID, id)
			}
		}
	})
}

// TestTable_SearchRange_CommentValidation 测试 SearchRange 函数的行为是否符合当前实现
// 验证：Start 和 Limit 必须包含相同的 key 值，并且只支持完全匹配的范围查询
func TestTable_SearchRange_CommentValidation(t *testing.T) {
	// 清理旧数据
	tableName := "test_search_range_comment_" + t.Name()
	defer os.RemoveAll("./test_search_range_comment_db")

	// 初始化数据库
	_, err := storage.OpenDefaultDb("./test_search_range_comment_db")
	if err != nil {
		t.Fatalf("打开数据库失败: %v", err)
	}
	defer storage.CloseDb()

	// 创建表
	table, err := TableNew(tableName)
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置字段
	fields := map[string]any{
		"id":    0,   // 主键
		"name":  "",  // 名称
		"value": 0.0, // 值
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置字段失败: %v", err)
	}

	// 创建主键索引
	pk, _ := DefaultPrimaryKeyNew("pk")
	pk.AddFields("id")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 生成测试数据
	testData := make([]map[string]any, 100)

	for i := 0; i < 100; i++ {
		testData[i] = map[string]any{
			"id":    i,
			"name":  fmt.Sprintf("item_%d", i),
			"value": float64(i * 10),
		}
	}

	// 插入测试数据
	for _, data := range testData {
		_, err := table.Insert(&data)
		if err != nil {
			t.Fatalf("插入数据失败: %v", err)
		}
	}

	// 定义迭代器函数
	funIter := storage.FunIter(func(start, limit []byte) storage.Iterator {
		return table.kvStore.Iterator(start, limit)
	})

	// 测试1: 完全匹配的索引查询
	t.Run("ExactMatchIndexQuery", func(t *testing.T) {
		// 设置测试点
		testID := 30

		// 执行完全匹配的范围查询
		iter, err := table.SearchRange(funIter, &map[string]any{"id": testID}, &map[string]any{"id": testID})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果数量
		expectedCount := 1 // 只返回完全匹配的记录
		if len(records) != expectedCount {
			t.Errorf("期望 %d 条记录，实际得到 %d 条", expectedCount, len(records))
		}

		// 验证结果
		if len(records) > 0 {
			id := records[0]["id"].(int)
			if id != testID {
				t.Errorf("期望 ID 为 %d，实际为 %d", testID, id)
			}
		}
	})

	// 测试2: 相同 key 值的验证
	t.Run("SameKeysValidation", func(t *testing.T) {
		// 执行相同 key 值的范围查询
		iter, err := table.SearchRange(funIter, &map[string]any{"id": 20}, &map[string]any{"id": 20})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果
		if len(records) > 0 {
			id := records[0]["id"].(int)
			if id != 20 {
				t.Errorf("期望 ID 为 20，实际为 %d", id)
			}
		}
	})

	// 测试3: 多字段相同 key 值的查询
	t.Run("MultiFieldSameKeys", func(t *testing.T) {
		// 创建复合索引
		idx, _ := DefaultNormalIndexNew("idx_name_value")
		idx.AddFields("name")
		idx.AddFields("value")
		err := table.CreateIndex(idx)
		if err != nil {
			t.Fatalf("创建复合索引失败: %v", err)
		}

		// 插入测试数据
		testData := map[string]any{
			"id":    100,
			"name":  "test",
			"value": 50.5,
		}
		_, err = table.Insert(&testData)
		if err != nil {
			t.Fatalf("插入测试数据失败: %v", err)
		}

		// 执行复合字段的完全匹配查询
		iter, err := table.SearchRange(funIter, &map[string]any{"name": "test", "value": 50.5}, &map[string]any{"name": "test", "value": 50.5})
		if err != nil {
			t.Fatalf("SearchRange 失败: %v", err)
		}
		defer iter.Release()

		// 获取结果
		records := iter.GetRecords(true)
		defer records.Release()

		// 验证结果
		for _, record := range records {
			name := record["name"].(string)
			value := record["value"].(float64)
			if name != "test" || value != 50.5 {
				t.Errorf("期望 name='test', value=50.5，实际 name='%s', value=%f", name, value)
			}
		}
	})
}

// TestTable_SearchRange_Performance 测试完全匹配范围查询的性能
func TestTable_SearchRange_Performance(t *testing.T) {
	// 跳过性能测试，除非明确指定
	if testing.Short() {
		t.Skip("跳过性能测试")
	}

	// 清理旧数据
	tableName := "test_search_range_perf_" + t.Name()
	defer os.RemoveAll("./test_search_range_perf_db")

	// 初始化数据库
	_, err := storage.OpenDefaultDb("./test_search_range_perf_db")
	if err != nil {
		t.Fatalf("打开数据库失败: %v", err)
	}
	defer storage.CloseDb()

	// 创建表
	table, err := TableNew(tableName)
	if err != nil {
		t.Fatalf("创建表失败: %v", err)
	}

	// 设置字段
	fields := map[string]any{
		"timestamp": 0,
		"value":     0.0,
		"sensor_id": "",
	}
	err = table.SetFields(fields)
	if err != nil {
		t.Fatalf("设置字段失败: %v", err)
	}

	// 创建主键索引
	pk, _ := DefaultPrimaryKeyNew("pk")
	pk.AddFields("timestamp")
	err = table.CreateIndex(pk)
	if err != nil {
		t.Fatalf("创建主键索引失败: %v", err)
	}

	// 生成大量测试数据
	now := int(time.Now().Unix())
	dataCount := 10000
	testData := make([]map[string]any, dataCount)

	for i := 0; i < dataCount; i++ {
		testData[i] = map[string]any{
			"timestamp": now + i,
			"value":     float64(i * 10),
			"sensor_id": fmt.Sprintf("sensor_%d", i%100),
		}
	}

	// 插入测试数据
	startTime := time.Now()
	for _, data := range testData {
		_, err := table.Insert(&data)
		if err != nil {
			t.Fatalf("插入数据失败: %v", err)
		}
	}
	insertTime := time.Since(startTime)
	t.Logf("插入 %d 条数据耗时: %v", dataCount, insertTime)

	// 测试性能
	t.Run("PerformanceTest", func(t *testing.T) {
		// 创建测试点
		testPoint := now + 5000

		// 定义迭代器函数
		funIter := storage.FunIter(func(start, limit []byte) storage.Iterator {
			// 使用存储引擎的Iterator方法创建范围迭代器
			return table.kvStore.Iterator(start, limit)
		})

		// 执行多次搜索，测试性能
		iterations := 10
		totalTime := 0

		for i := 0; i < iterations; i++ {
			startTime := time.Now()

			// 执行完全匹配的范围查询
			iter, err := table.SearchRange(funIter, &map[string]any{"timestamp": testPoint}, &map[string]any{"timestamp": testPoint})
			if err != nil {
				t.Fatalf("SearchRange 失败: %v", err)
			}

			// 获取结果
			records := iter.GetRecords(true)

			// 释放资源
			records.Release()
			iter.Release()

			searchTime := time.Since(startTime).Milliseconds()
			totalTime += int(searchTime)
			t.Logf("第 %d 次搜索耗时: %d ms", i+1, searchTime)
		}

		averageTime := totalTime / iterations
		t.Logf("平均搜索耗时: %d ms", averageTime)

		// 性能阈值检查
		if averageTime > 100 {
			t.Logf("搜索性能可能需要优化，平均耗时 %d ms", averageTime)
		}
	})
}
