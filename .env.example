# sfsEdgeStore 配置文件
# 复制此文件为 .env 并修改为实际值

# 数据库配置
EDGEX_DB_PATH=./edgex_data
EDGEX_DB_USE_ENCRYPTION=false
EDGEX_DB_ENCRYPTION_KEY=
EDGEX_DB_ENCRYPTION_ALGORITHM=AES-256-GCM
EDGEX_DB_SCENARIO=edge

# MQTT 配置
EDGEX_MQTT_BROKER=tcp://localhost:1883
EDGEX_MQTT_TOPIC=edgex/events/core/#
EDGEX_CLIENT_ID=sfsdb-edgex-adapter
EDGEX_MQTT_USE_TLS=false
EDGEX_MQTT_CA_CERT=
EDGEX_MQTT_CLIENT_CERT=
EDGEX_MQTT_CLIENT_KEY=

# HTTP 服务配置
EDGEX_HTTP_PORT=8081
EDGEX_HTTP_USE_TLS=false
EDGEX_HTTP_CERT=
EDGEX_HTTP_KEY=

# 分析引擎配置
EDGEX_ENABLE_ANALYZER=false
EDGEX_ANALYZER_MAX_MEMORY=10485760
EDGEX_ANALYZER_MAX_TIME_PER_RUN=500

# 数据保留策略配置
EDGEX_ENABLE_RETENTION_POLICY=true
EDGEX_RETENTION_DAYS=30
EDGEX_CLEANUP_INTERVAL_HOURS=24
EDGEX_CLEANUP_BATCH_SIZE=1000

# 告警通知配置
EDGEX_ENABLE_ALERT_NOTIFICATIONS=false
EDGEX_ALERT_NOTIFICATION_CHANNELS=
EDGEX_ALERT_MQTT_TOPIC=edgex/alerts
EDGEX_ALERT_WEBHOOK_URL=
EDGEX_ALERT_MIN_SEVERITY=warning

# 数据同步配置
EDGEX_ENABLE_DATA_SYNC=false
EDGEX_DATA_SYNC_MQTT_TOPIC=edgex/data/sync
EDGEX_DATA_SYNC_QUEUE_DIR=./data_sync_queue
EDGEX_DATA_SYNC_BATCH_SIZE=100
EDGEX_DATA_SYNC_INTERVAL_SECONDS=30
EDGEX_DATA_SYNC_MAX_RETRY_COUNT=5

# 资源监控配置
EDGEX_ENABLE_RESOURCE_MONITORING=true
EDGEX_MAX_MEMORY_MB=50
EDGEX_MAX_CPU_PERCENT=5
EDGEX_RESOURCE_MONITOR_INTERVAL_SECONDS=10

# Prometheus 指标配置（可选，默认关闭）
EDGEX_ENABLE_PROMETHEUS=false
EDGEX_PROMETHEUS_PATH=/metrics
